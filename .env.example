# user-service/.env.example
# Copia a .env y completa valores. NO subas .env al repo.

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Base de datos
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=admin
DATABASE_PASSWORD=changeme
DATABASE_NAME=user-service-db
DATABASE_SCHEMA=public

# NOTA: este servicio actualmente NO valida JWT. Si se añade autenticación,
# JWT_SECRET debe ser el MISMO valor que en los demás microservicios.
# JWT_SECRET=

# CORS: orígenes permitidos separados por coma
CORS_ORIGINS=http://localhost:3004,http://localhost:3005

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
